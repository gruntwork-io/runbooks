{
  "name": "molecular-mercury",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "cd ../testdata/sample-runbooks && zip -r ../../docs/public/my-first-runbook.zip my-first-runbook",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "spellcheck": "cspell \"src/content/**/*.{md,mdx}\" --no-progress",
    "spellcheck:fix": "cspell \"src/content/**/*.{md,mdx}\" --no-progress --show-suggestions",
    "linkcheck": "linkinator ./dist --recurse --skip 'github.com' --skip 'localhost'",
    "linkcheck:external": "linkinator ./dist --recurse"
  },
  "dependencies": {
    "@astrojs/starlight": "0.39.2",
    "@vercel/analytics": "2.0.1",
    "astro": "6.4.6",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "cspell": "10.0.0",
    "linkinator": "7.6.1"
  }
}
