---
/**
 * SourceFile - Displays source file contents from the repository at build time.
 * 
 * Usage in .mdx files:
 *   import SourceFile from '../../components/SourceFile.astro';
 *   <SourceFile file="testdata/my-first-runbook/runbook.mdx" lang="mdx" />
 * 
 * Props:
 *   - file: Path relative to repo root (not docs folder)
 *   - lang: Language for syntax highlighting
 *   - title: Optional display title (defaults to filename)
 */
import fs from 'node:fs';
import path from 'node:path';
import { Code } from '@astrojs/starlight/components';

interface Props {
  file: string;
  lang: string;
  title?: string;
  /** Hide the filename heading — useful when embedded inside content that already has its own heading (e.g. Steps). */
  hideTitle?: boolean;
}

const { file, lang, title, hideTitle } = Astro.props;

// Resolve path relative to the repo root. We anchor on process.cwd() (the docs
// project root during both `astro dev` and `astro build`) rather than
// import.meta.dirname: Astro 6 bundles component frontmatter into dist/.prerender
// chunks at build time, so import.meta.dirname no longer points at this source
// file. testdata/ lives one level up at the repo root.
const repoRoot = path.resolve(process.cwd(), '..');
const absolutePath = path.resolve(repoRoot, file);
const displayTitle = title || path.basename(file);

let content = '';
let error = '';

try {
  content = fs.readFileSync(absolutePath, 'utf-8');
} catch (e) {
  error = `Could not read file: ${file}`;
  console.error(error, e);
}
---

{!hideTitle && <h3><code>{displayTitle}</code></h3>}

{error ? (
  <div style="color: red; padding: 1rem; border: 1px solid red; border-radius: 4px;">
    ⚠️ {error}
  </div>
) : (
  <Code code={content} lang={lang} />
)}

