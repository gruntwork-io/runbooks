---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Code } from "@astrojs/starlight/components";
import { generateLlmsTxt } from "../lib/llms-content";

const content = await generateLlmsTxt();
---

<StarlightPage
  frontmatter={{
    title: "Author with AI",
    description: "Copy the full Runbooks documentation to paste into an LLM for help authoring runbooks.",
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <div class="llms-page">
    <p class="llms-intro">
      Use your favorite LLM (ChatGPT, Claude, etc.) to help you write Gruntwork Runbooks.
    </p>

    <h3>How to use it</h3>
    <ol>
      <li>Copy the following prompt into your LLM:
        <Code code="Write me a runbook that [describe what you want the runbook to do].\nUse the following context to help you write the runbook, which is the complete Runbooks documentation." lang="text" />
      </li>
      <li>Copy the <strong>LLM context</strong> below and paste it into the same message.</li>
      <li>Send it! The LLM will have full knowledge of all available blocks, props, and conventions.</li>
    </ol>
    <p>
      For best results, be specific about what your runbook should do: which tools it installs, what inputs it collects,
      what scripts it runs, and what checks it performs.
    </p>

    <hr />

    <h2>LLM Context</h2>
    <div class="llms-actions">
      <button class="llms-btn llms-btn-primary" id="copy-btn">Copy to clipboard</button>
      <a href="/llms.txt">View raw text (/llms.txt)</a>
    </div>
    <div class="llms-content-box">
      <pre id="llms-content" set:text={content} />
    </div>
    <p class="llms-stats" id="stats"></p>
  </div>

  <script is:inline>
    const content = document.getElementById("llms-content").textContent;

    const statsEl = document.getElementById("stats");
    const chars = content.length;
    const words = content.split(/\s+/).length;
    const approxTokens = Math.round(words * 1.3);
    statsEl.textContent = `${chars.toLocaleString()} characters · ~${words.toLocaleString()} words · ~${approxTokens.toLocaleString()} tokens`;

    const btn = document.getElementById("copy-btn");
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(content);
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = content;
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      }
      btn.textContent = "Copied!";
      btn.classList.add("copied");
      setTimeout(() => {
        btn.textContent = "Copy to clipboard";
        btn.classList.remove("copied");
      }, 2000);
    });
  </script>
</StarlightPage>

<style>
  .llms-page {
    max-width: 100%;
  }
  .llms-intro {
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .llms-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin: 0.75rem 0 1rem;
    flex-wrap: wrap;
  }
  .llms-btn {
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    cursor: pointer;
    font-weight: 500;
    transition: opacity 0.15s;
  }
  .llms-btn:hover { opacity: 0.85; }
  .llms-btn-primary {
    background: var(--sl-color-accent);
    color: white;
  }
  .llms-btn.copied {
    background: #16a34a !important;
    color: #fff !important;
  }
  .llms-content-box {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    max-height: 600px;
    overflow-y: auto;
  }
  .llms-content-box pre {
    white-space: pre-wrap;
    word-wrap: break-word;
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
  }
  .llms-stats {
    color: var(--sl-color-gray-3);
    font-size: 0.8rem;
    margin-top: 0.5rem;
  }
  hr {
    border: none;
    border-top: 1px solid var(--sl-color-gray-5);
    margin: 2rem 0;
  }
</style>
