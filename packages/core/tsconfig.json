{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "domain/**/*",
    "errors/**/*",
    "layers/**/*",
    "services/**/*",
    "test-utils/**/*",
    "types.ts",
    "mdx.ts",
    "mdx.test.ts",
    "telemetry.ts",
    "watcher.ts",
    "path-validation.ts",
    "path-validation.test.ts",
    "remote-source.ts",
    "remote-source.test.ts"
  ]
}
