#!/bin/bash
# Cloud-init script for OpenClaw EC2 instance
# Installs Docker and runs OpenClaw in a container.
# Access is via SSM Session Manager port forwarding — no public ports needed.
set -euo pipefail

exec > >(tee /var/log/openclaw-setup.log) 2>&1
echo "=== OpenClaw setup started at $(date) ==="

# ---------------------------------------------------------------------------------------------------------------------
# SYSTEM UPDATE
# ---------------------------------------------------------------------------------------------------------------------

echo ">>> Updating system packages..."
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get upgrade -y

# ---------------------------------------------------------------------------------------------------------------------
# INSTALL DOCKER
# Install Docker CE from the official Docker repository.
# https://docs.docker.com/engine/install/ubuntu/
# ---------------------------------------------------------------------------------------------------------------------

echo ">>> Installing Docker..."
apt-get install -y ca-certificates curl gnupg

install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
  $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | \
  tee /etc/apt/sources.list.d/docker.list > /dev/null

apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin

systemctl enable docker
systemctl start docker

# Add ubuntu user to docker group
usermod -aG docker ubuntu

echo ">>> Docker installed successfully"

# ---------------------------------------------------------------------------------------------------------------------
# GENERATE GATEWAY PASSWORD
# Create a random password for OpenClaw gateway authentication.
# ---------------------------------------------------------------------------------------------------------------------

OPENCLAW_PASSWORD=$(openssl rand -base64 24)
echo "$OPENCLAW_PASSWORD" > /home/ubuntu/.openclaw-password
chown ubuntu:ubuntu /home/ubuntu/.openclaw-password
chmod 600 /home/ubuntu/.openclaw-password

echo ">>> Gateway password generated and saved to /home/ubuntu/.openclaw-password"

# ---------------------------------------------------------------------------------------------------------------------
# RUN OPENCLAW
# Start OpenClaw in a Docker container with automatic restart.
# OpenClaw binds to 127.0.0.1 by default — access is via SSM port forwarding.
# ---------------------------------------------------------------------------------------------------------------------

echo ">>> Starting OpenClaw container..."
docker run -d \
  --name openclaw \
  --restart=always \
  --network host \
  -e OPENCLAW_GATEWAY_PORT=${gateway_port} \
  -e OPENCLAW_GATEWAY_PASSWORD="$OPENCLAW_PASSWORD" \
  -v openclaw-data:/app/data \
  alpine/openclaw:${openclaw_version}

echo ">>> OpenClaw container started"

# ---------------------------------------------------------------------------------------------------------------------
# CONFIGURE OPENCLAW
# Set password auth mode so the Control UI works without device pairing.
# ---------------------------------------------------------------------------------------------------------------------

echo ">>> Configuring OpenClaw gateway..."

# Wait for the container to be healthy before configuring
for i in $(seq 1 30); do
  if docker exec openclaw openclaw config set gateway.auth.mode password 2>/dev/null; then
    echo ">>> OpenClaw configured for password auth"
    docker restart openclaw
    break
  fi
  sleep 5
done

# ---------------------------------------------------------------------------------------------------------------------
# SETUP COMPLETE
# ---------------------------------------------------------------------------------------------------------------------

echo ""
echo "============================================"
echo "  OpenClaw setup complete!"
echo ""
echo "  Access via SSM port forwarding:"
echo "    aws ssm start-session --target $(curl -s http://169.254.169.254/latest/meta-data/instance-id) \\"
echo "      --document-name AWS-StartPortForwardingSession \\"
echo "      --parameters '{\"portNumber\":[\"${gateway_port}\"],\"localPortNumber\":[\"${gateway_port}\"]}'"
echo ""
echo "  Then open: http://localhost:${gateway_port}"
echo "  Password: saved to /home/ubuntu/.openclaw-password"
echo "============================================"
echo ""
echo "=== OpenClaw setup finished at $(date) ==="
