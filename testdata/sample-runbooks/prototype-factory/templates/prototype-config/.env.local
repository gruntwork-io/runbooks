# ============================================================
# {{ .ProjectName }} — Local Environment Configuration
# Generated by the Prototype Factory runbook
# ============================================================

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL={{ .SupabaseUrl }}
NEXT_PUBLIC_SUPABASE_ANON_KEY={{ .SupabaseAnonKey }}

# --- Conversation Service API ---
CONVERSATION_API_URL=http://localhost:8001
LLM_PROVIDER={{ .LlmProvider }}

# --- Content Service API ---
CONTENT_API_URL=http://localhost:8002

# --- Vector Database (Pinecone) ---
PINECONE_API_KEY={{ .PineconeApiKey }}
PINECONE_ENVIRONMENT={{ .PineconeEnvironment }}
PINECONE_INDEX={{ .ProjectName }}-index

# --- Cache & Rate Limiting (Upstash Redis) ---
UPSTASH_REDIS_URL={{ .UpstashRedisUrl }}
RATE_LIMIT_RPM=60
RATE_LIMIT_RPD=1000

# --- Telemetry (LangSmith) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY={{ .LangSmithApiKey }}
LANGCHAIN_PROJECT={{ .ProjectName }}
