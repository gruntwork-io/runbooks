{
  "description": "Shared test cases for output dependency extraction regex. Both Go (api/boilerplate_config.go) and TypeScript (web/src/lib/extractTemplateDependencies.ts) implementations must pass these tests to ensure they stay in sync.",
  "pattern_description": "Matches {{ .outputs.blockId.outputName }} patterns with optional whitespace and pipe functions",
  "cases": [
    {
      "name": "basic pattern with spaces",
      "input": "{{ .outputs.create-account.account_id }}",
      "expected": [
        { "blockId": "create-account", "outputName": "account_id" }
      ]
    },
    {
      "name": "basic pattern without spaces",
      "input": "{{.outputs.foo.bar}}",
      "expected": [
        { "blockId": "foo", "outputName": "bar" }
      ]
    },
    {
      "name": "pattern with pipe function",
      "input": "{{ .outputs.my-block.value | UpperCase }}",
      "expected": [
        { "blockId": "my-block", "outputName": "value" }
      ]
    },
    {
      "name": "pattern with multiple pipe functions",
      "input": "{{ .outputs.block1.name | lower | trimSpace }}",
      "expected": [
        { "blockId": "block1", "outputName": "name" }
      ]
    },
    {
      "name": "no dependencies",
      "input": "No output dependencies here, just plain text",
      "expected": []
    },
    {
      "name": "multiple different dependencies",
      "input": "Account: {{ .outputs.create-account.account_id }} Region: {{ .outputs.setup-region.region_name }}",
      "expected": [
        { "blockId": "create-account", "outputName": "account_id" },
        { "blockId": "setup-region", "outputName": "region_name" }
      ]
    },
    {
      "name": "duplicate dependencies should be deduplicated",
      "input": "First: {{ .outputs.block-a.value }} Second: {{ .outputs.block-a.value }}",
      "expected": [
        { "blockId": "block-a", "outputName": "value" }
      ]
    },
    {
      "name": "block id with underscores",
      "input": "{{ .outputs.my_block_name.result }}",
      "expected": [
        { "blockId": "my_block_name", "outputName": "result" }
      ]
    },
    {
      "name": "block id with numbers",
      "input": "{{ .outputs.step1.output2 }}",
      "expected": [
        { "blockId": "step1", "outputName": "output2" }
      ]
    },
    {
      "name": "mixed alphanumeric block id",
      "input": "{{ .outputs.create-ec2-instance-v2.instance_id }}",
      "expected": [
        { "blockId": "create-ec2-instance-v2", "outputName": "instance_id" }
      ]
    },
    {
      "name": "embedded in terraform template",
      "input": "resource \"aws_instance\" \"main\" {\n  ami = \"{{ .outputs.get-ami.ami_id }}\"\n  instance_type = \"t3.micro\"\n  tags = {\n    Account = \"{{ .outputs.create-account.account_name | UpperCase }}\"\n  }\n}",
      "expected": [
        { "blockId": "get-ami", "outputName": "ami_id" },
        { "blockId": "create-account", "outputName": "account_name" }
      ]
    },
    {
      "name": "input variables should not match",
      "input": "{{ .inputs.AccountName }} {{ .inputs.Environment }}",
      "expected": []
    },
    {
      "name": "partial patterns should not match",
      "input": "{{ .outputs.incomplete }} {{ .inputs.something }}",
      "expected": []
    },
    {
      "name": "extra whitespace variations",
      "input": "{{   .outputs.block1.val   }}",
      "expected": [
        { "blockId": "block1", "outputName": "val" }
      ]
    },
    {
      "name": "same block multiple outputs",
      "input": "ID: {{ .outputs.setup.id }} Name: {{ .outputs.setup.name }}",
      "expected": [
        { "blockId": "setup", "outputName": "id" },
        { "blockId": "setup", "outputName": "name" }
      ]
    },
    {
      "name": "inside fromJson function call",
      "input": "{{- range (fromJson .outputs.list_users.users) }}\n- {{ . }}\n{{- end }}",
      "expected": [
        { "blockId": "list_users", "outputName": "users" }
      ]
    },
    {
      "name": "inside fromJson with range assignment",
      "input": "{{- range $k, $v := (fromJson .outputs.list_users.teams) }}\n{{ $k }}\n{{- end }}",
      "expected": [
        { "blockId": "list_users", "outputName": "teams" }
      ]
    },
    {
      "name": "reference outside template delimiters should not match",
      "input": "# This comment mentions .outputs.setup.id but is not inside {{ }}",
      "expected": []
    },
    {
      "name": "reference in plain text between template blocks should not match",
      "input": "{{ .inputs.SomeVar }} then .outputs.setup.id appears outside {{ .inputs.OtherVar }}",
      "expected": []
    },
    {
      "name": "mixed: one inside delimiters, one outside should only match the inside one",
      "input": ".outputs.outside.nope {{ .outputs.inside.yes }}",
      "expected": [
        { "blockId": "inside", "outputName": "yes" }
      ]
    }
  ]
}
